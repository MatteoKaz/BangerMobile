%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7607cb61f2949904a92fbce6593881ba, type: 3}
  m_Name: Employes 1
  m_EditorClassIdentifier: Assembly-CSharp::EmployeObject
  allEmploye:
  - EmployeName: Arthur
    description: "Arthur s'occupe de v\xE9rifier que toutes les d\xE9cisions respectent
      bien les r\xE8gles de l\u2019entreprise. Strict et inflexible, il ne tol\xE8re
      aucune approximation. Peu appr\xE9ci\xE9 par ses coll\xE8gues, d\xFB \xE0 son
      intransigeance maladive et \xE0 son c\xF4t\xE9 \"grande gueule\" m\xE9galomane.
      Les femmes de la bo\xEEte pr\xE9f\xE8rent l'\xE9viter, ne cessant de se vanter
      de ses multiples conqu\xEAtes. Mais ainsi, malgr\xE9 son comportement, il reste
      un maillon indispensable de l'entreprise afin d'\xE9viter les erreurs graves.\L
      Si jamais il venait \xE0 perdre son travail, cela lui ferait un sacr\xE9 coup
      \xE0 l'ego, qu'il ferait probablement payer cher \xE0 l'entreprise."
    type: 0
    TypeText: Rapide/fautif
    workRythme: 4
    errorPercent: 0.65
    timeInEntreprise: 0
    typeSprite: {fileID: -9205446280149291036, guid: 2661d2b11b84bee4e891387ac5b7bd0f, type: 3}
    firelines:
    - text: "C'est une blague ? Vous avez besoin de moi. Le seul homme fort et comp\xE9tent
        de la boite. "
      speed: 0.02
    firelinesChoice:
    - text: "Bonne chance sans moi\u2026 vous allez cumuler les erreurs."
      speed: 0.03
    notfirelines:
    - text: "Vous allez regretter d\u2019avoir essay\xE9 de vous d\xE9barrasser de
        moi."
      speed: 0.03
    icone: {fileID: 21300000, guid: e270274b849fbfb49a0f1246e281e5db, type: 3}
    Working: {fileID: 21300000, guid: d76a97f462a28ed43b2745bee89e6c17, type: 3}
    Surcharge: {fileID: 21300000, guid: ed70fe2c83a91c24d8a42593841e7aeb, type: 3}
  - EmployeName: Sam
    description: "Sam est le \"touche-\xE0-tout\" de l'entreprise. Il n'a pas de
      sp\xE9cialit\xE9, mais il se d\xE9marque justement par sa polyvalence. D\xE8s
      que quelqu'un a besoin de support sur une t\xE2che, il vient \xE0 la rescousse.\L
      En revanche, ce dernier a tendance \xE0 facilement se d\xE9concentrer et \xE0
      vite accumuler les t\xE2ches, devant les g\xE9rer en m\xEAme temps.\L \xC9galement,
      son comportement impr\xE9visible est souvent relev\xE9 par ses coll\xE8gues
      : observant ces derniers sans dire un mot, ou encore venant au bureau d\xE9guis\xE9
      en Spider-Man.\L Ainsi, malgr\xE9 ses bizarreries, le bureau semble \xEAtre
      le seul endroit o\xF9 ce dernier puisse \xEAtre lui-m\xEAme."
    type: 2
    TypeText: Stable
    workRythme: 5.5
    errorPercent: 0.8
    timeInEntreprise: 0
    typeSprite: {fileID: 7174708238663027378, guid: 7ded8aa5b57241041a3741eab8ae02dc, type: 3}
    firelines:
    - text: "Euh... C\u2019est une blague ?"
      speed: 0.02
    firelinesChoice:
    - text: "Oh\u2026 d'accord\u2026 je vois je m\u2019y attendais pas\u2026"
      speed: 0.02
    notfirelines:
    - text: Ah ! Plot twist ! Je suis de retour !
      speed: 0.02
    icone: {fileID: 21300000, guid: 14f9bb138c4e86f4c8e0a13e389950c2, type: 3}
    Working: {fileID: 21300000, guid: 141afca3c9c3e9a46bbcd97a11f5c067, type: 3}
    Surcharge: {fileID: 21300000, guid: 34a1bffddc005c444a9e87740fea54a2, type: 3}
  - EmployeName: John
    description: "John, le doyen de l'entreprise, s'occupe de classer les dossiers.
      Il conna\xEEt toutes les proc\xE9dures sur le bout des doigts.\L Peu \xE0 l\u2019aise
      avec les nouvelles technologies, il pr\xE9f\xE8re travailler comme \xE0 l'\xE9poque,
      \xE0 savoir : sans utiliser l'informatique \xE0 outrance. Seulement, cela a
      tendance \xE0 rallonger quelque peu certaines proc\xE9dures. De plus, ses r\xE9cents
      probl\xE8mes de m\xE9moire, dus \xE0 son \xE2ge grandissant, n'arrangent pas
      les choses. Pour autant, John reste ainsi un employ\xE9 central de l'entreprise
      et, \xE0 seulement quelques mois de la retraite, ce serait cruel de se d\xE9barrasser
      de cette vieille branche maintenant, non ?"
    type: 1
    TypeText: "Lent/Appliqu\xE9"
    workRythme: 7
    errorPercent: 0.9
    timeInEntreprise: 0
    typeSprite: {fileID: 402761151100828559, guid: 8e8f8647c2b0bd74d930e847c2cd4a68, type: 3}
    firelines:
    - text: "Apr\xE8s toutes ces ann\xE9es \xE0 servir l'entreprise\u2026 vous ne
        pouvez pas me faire \xE7a ?! "
      speed: 0.02
    firelinesChoice:
    - text: "Je\u2026 j\u2019\xE9tais presque \xE0 la retraite\u2026"
      speed: 0.02
    notfirelines:
    - text: "Oh! Merci\u2026 je ne ferai plus d\u2019erreurs je vous assure\u2026"
      speed: 0.02
    icone: {fileID: 21300000, guid: 0a68844e2e9cb274587eb7d65d93eae0, type: 3}
    Working: {fileID: 21300000, guid: 070f6e68f0b8f3b499dbbd74209d851e, type: 3}
    Surcharge: {fileID: 21300000, guid: c725b2e1fbb3cff4fa1130aca58cc62a, type: 3}
  - EmployeName: Tomy
    description: "Tomy est l'homme de la situation concernant les cas les plus complexes
      de l'entreprise, intervenant en premi\xE8re ligne d\xE8s lors que le client
      r\xE9clame son indemnisation.\L P\xE8re de trois enfants, il se retrouve souvent
      d\xE9bord\xE9 par sa vie personnelle empi\xE9tant sur sa vie professionnelle,
      ayant tendance \xE0 agacer ses coll\xE8gues, ne cessant d'exhiber fi\xE8rement
      les photos de ses enfants. Ainsi, bien que quelque peu collant et ben\xEAt,
      il reste pour autant un tr\xE8s bon employ\xE9 et coll\xE8gue, faisant preuve
      d\u2019une grande empathie."
    type: 0
    TypeText: Rapide/fautif
    workRythme: 4
    errorPercent: 0.65
    timeInEntreprise: 0
    typeSprite: {fileID: -9205446280149291036, guid: 2661d2b11b84bee4e891387ac5b7bd0f, type: 3}
    firelines:
    - text: "Attendez\u2026 je peux m'am\xE9liorer ! Ne faites pas \xE7a j'ai trois
        enfants \xE0 nourrir !"
      speed: 0.02
    firelinesChoice:
    - text: "Mes enfants\u2026 Comment je vais faire\u2026"
      speed: 0.02
    notfirelines:
    - text: "Merci\u2026 vraiment, merci\u2026"
      speed: 0.02
    icone: {fileID: 21300000, guid: ae6104a4f1aafd04c815a15c342c322a, type: 3}
    Working: {fileID: 21300000, guid: 413e3607708b3b14ca7e1b2af6617ca8, type: 3}
    Surcharge: {fileID: 21300000, guid: 5c8ff4fc1d5f16c43a708c1ec93f2f10, type: 3}
  - EmployeName: Taylor
    description: "Taylor s'occupe d\u2019authentifier et de contr\xF4ler les fonds
      entrants. Petit nouveau \xE9nergique, beaucoup de ses coll\xE8gues profitent
      de sa na\xEFvet\xE9, n'h\xE9sitant pas \xE0 lui d\xE9l\xE9guer leurs t\xE2ches.
      Cependant, ce dernier n'est pas pour autant efficace. D\xE9testant relire son
      travail, il n\xE9glige ainsi souvent de nombreux d\xE9tails dans les documents
      qu'il traite.\L Lui qui \xE9tait originellement en stage dans l'entreprise
      a fini par d\xE9crocher un CDI qui, suite au probl\xE8me de sant\xE9 de sa
      m\xE8re, est devenu une opportunit\xE9 plus que vitale."
    type: 1
    TypeText: "Lent/Appliqu\xE9"
    workRythme: 7
    errorPercent: 0.9
    timeInEntreprise: 0
    typeSprite: {fileID: 402761151100828559, guid: 8e8f8647c2b0bd74d930e847c2cd4a68, type: 3}
    firelines:
    - text: "Attendez ! Ne faites pas \xE7a je vous en supplie. Ma m\xE8re est gravement
        malade !"
      speed: 0.02
    firelinesChoice:
    - text: "Non\u2026 J\u2019avais vraiment besoin de ce travail... Maman..."
      speed: 0.02
    notfirelines:
    - text: "Vous \xEAtes trop bon, merci, vous \xEAtes le meilleur des patrons,
        le plus grand, le plus beau, le plus gentil."
      speed: 0.02
    icone: {fileID: 21300000, guid: 7bf0d99247ede4645b1623de9a534709, type: 3}
    Working: {fileID: 21300000, guid: 04d60c2589bee244f86fa3b915dce805, type: 3}
    Surcharge: {fileID: 21300000, guid: a7d1402b9224e8a4d9d0675c4c8fe25b, type: 3}
  - EmployeName: Jade
    description: "Jade s\u2019occupe d\u2019optimiser la circulation des dossiers
      entre les diff\xE9rents services.\L Elle se d\xE9marque par son efficacit\xE9,
      ne s\u2019\xE9garant pas dans des discussions futiles. Certains coll\xE8gues
      la trouvent froide, mais pour elle, elle est simplement une employ\xE9e mod\xE8le.
      Sa vision d'elle-m\xEAme, quelque peu \xE9gocentr\xE9e, a tendance \xE0 agacer
      ses coll\xE8gues, allant jusqu'\xE0 \xE9viter cette derni\xE8re. Mais ainsi,
      au-del\xE0 de ses relations sociales bancales au sein de l'entreprise, sa productivit\xE9
      est fortement appr\xE9ci\xE9e par ses sup\xE9rieurs."
    type: 2
    TypeText: Stable
    workRythme: 5.5
    errorPercent: 0.8
    timeInEntreprise: 0
    typeSprite: {fileID: 7174708238663027378, guid: 7ded8aa5b57241041a3741eab8ae02dc, type: 3}
    firelines:
    - text: Laissez moi vous dire que vous faites une grosse erreur.
      speed: 0.02
    firelinesChoice:
    - text: "D\xE9cision compl\xE8tement irrationnel "
      speed: 0.02
    notfirelines:
    - text: "Logique. Vous avez corrig\xE9."
      speed: 0.02
    icone: {fileID: 21300000, guid: 52f806f274acbbb4697b579b6a2a37f5, type: 3}
    Working: {fileID: 21300000, guid: 3ed0255ef51dea6479e14a8302b42898, type: 3}
    Surcharge: {fileID: 21300000, guid: a003a2d67afba944487de9762a5abc81, type: 3}
  - EmployeName: Skyler
    description: "Skyler est sp\xE9cialis\xE9e dans la validation des dossiers les
      plus sensibles de la bo\xEEte. Particuli\xE8rement rigoureuse, elle rep\xE8re
      vite les erreurs. En revanche, son perfectionnisme a tendance \xE0 lui jouer
      des tours, ralentissant sa fr\xE9quence de travail.\L Ne supportant pas les
      j\xE9r\xE9miades et ragots de ses coll\xE8gues, elle pr\xE9f\xE8re travailler
      seule.\L C\xE9libataire endurcie, Skyler s'occupe seule de ses deux enfants,
      son salaire \xE9tant le seul revenu pour subvenir \xE0 leurs besoins. Sans
      ce travail, elle serait probablement d\xE9j\xE0 condamn\xE9e..."
    type: 0
    TypeText: Rapide/fautif
    workRythme: 4
    errorPercent: 0.65
    timeInEntreprise: 0
    typeSprite: {fileID: -9205446280149291036, guid: 2661d2b11b84bee4e891387ac5b7bd0f, type: 3}
    firelines:
    - text: "Faites ce que vous avez \xE0 faire je m'en fiche. Moi je fais mon travail."
      speed: 0.02
    firelinesChoice:
    - text: "Tr\xE8s bien. Bonne chance sans la seule personne r\xE9ellement comp\xE9tente
        de la boite."
      speed: 0.02
    notfirelines:
    - text: "\u2026Je suppose que vous avez compris votre erreur."
      speed: 0.03
    icone: {fileID: 21300000, guid: 859752bb043b03642a97ae006c246051, type: 3}
    Working: {fileID: 21300000, guid: b11db67f4b20aba46931026596be6b2a, type: 3}
    Surcharge: {fileID: 21300000, guid: bae84d74c689b2b4a9275fbbe3141384, type: 3}
  - EmployeName: Julie
    description: "Julie est charg\xE9e d\u2019accompagner les nouveaux employ\xE9s.\L
      Patiente et p\xE9dagogue, elle prend le temps d\u2019expliquer les diff\xE9rentes
      proc\xE9dures, parfois au d\xE9triment des performances. Elle ne peut s'emp\xEAcher
      de parler, les comm\xE9rages \xE9tant du pain b\xE9ni pour elle. Seulement,
      bien que sa pr\xE9sence soit appr\xE9ci\xE9e par ses coll\xE8gues, ses sup\xE9rieurs
      doivent souvent la reprendre.\L Les bruits de couloir affirment que, si elle
      ne peut s'emp\xEAcher de parler, cela est d\xFB \xE0 sa profonde solitude personnelle.
      Ainsi, perdre son travail serait un profond drame pour elle."
    type: 1
    TypeText: "Lent/Appliqu\xE9"
    workRythme: 7
    errorPercent: 0.9
    timeInEntreprise: 0
    typeSprite: {fileID: 402761151100828559, guid: 8e8f8647c2b0bd74d930e847c2cd4a68, type: 3}
    firelines:
    - text: "Oh non ! ne faites pas \xE7a ! vous savez que je peux m\u2019am\xE9liorer
        !"
      speed: 0.02
    firelinesChoice:
    - text: Mais, qu'est ce que je vais devenir sans ce travail maintenant...
      speed: 0.02
    notfirelines:
    - text: "Je savais que vous alliez changer d\u2019avis !"
      speed: 0.02
    icone: {fileID: 21300000, guid: f259354f6b8dc72418db5fcc84fe6853, type: 3}
    Working: {fileID: 21300000, guid: 27b6ce3f2058e834aa883873d18698ae, type: 3}
    Surcharge: {fileID: 21300000, guid: 8c4f88154130a7540b3bbc54e8afa46e, type: 3}
  - EmployeName: Grace
    description: "Grace assure la liaison entre les diff\xE9rents services de l\u2019entreprise.
      Gr\xE2ce \xE0 son aisance \xE0 l'oral, elle sait apaiser les tensions entre
      ses coll\xE8gues. Cependant, elle se laisse vite submerger par le stress lorsqu\u2019on
      lui confie trop de responsabilit\xE9s.\L Couverte de dettes, ce travail lui
      est indispensable pour esp\xE9rer sortir la t\xEAte de l'eau. Si jamais elle
      venait \xE0 perdre ce dernier, elle perdrait ainsi sa seule rentr\xE9e d'argent
      pour \xE9ponger ses dettes. Alors, r\xE9fl\xE9chissez bien si vous souhaitez
      la licencier, n'avez-vous donc pas de c\u0153ur ?"
    type: 2
    TypeText: Stable
    workRythme: 5.5
    errorPercent: 0.8
    timeInEntreprise: 0
    typeSprite: {fileID: 7174708238663027378, guid: 7ded8aa5b57241041a3741eab8ae02dc, type: 3}
    firelines:
    - text: "S\u2019il vous pla\xEEt\u2026 je peux pas perdre ce travail."
      speed: 0.02
    firelinesChoice:
    - text: "\u2026Vous venez de ruiner ma vie."
      speed: 0.02
    notfirelines:
    - text: "Merci\u2026 vraiment."
      speed: 0.02
    icone: {fileID: 21300000, guid: ae27765a14492f741afc5ed94eedd606, type: 3}
    Working: {fileID: 21300000, guid: 014277cd6bd730a4c982b10eea872d0f, type: 3}
    Surcharge: {fileID: 21300000, guid: 46abfc4b515771e43801137896c67dfe, type: 3}
  - EmployeName: Harper
    description: "Harper est une employ\xE9e discr\xE8te, distinguant vie professionnelle
      et personnelle, ne se laissant pas perturber par les blagues de ses coll\xE8gues.\L
      Elle ex\xE9cute sans broncher les diff\xE9rentes t\xE2ches qu'on lui confie.
      Seulement, cette derni\xE8re manque cruellement d\u2019initiative et fait rarement
      plus que ce qu\u2019on lui demande.\L Harper est une jeune femme efficace,
      mais sa discr\xE9tion la rend bien myst\xE9rieuse : ne divulguant rien de sa
      vie personnelle, personne ne sait r\xE9ellement qui elle est."
    type: 0
    TypeText: Rapide/fautif
    workRythme: 4
    errorPercent: 0.65
    timeInEntreprise: 0
    typeSprite: {fileID: -9205446280149291036, guid: 2661d2b11b84bee4e891387ac5b7bd0f, type: 3}
    firelines:
    - text: "\u2026Si c\u2019est ce que vous souhaitez."
      speed: 0.02
    firelinesChoice:
    - text: "D\u2019accord."
      speed: 0.02
    notfirelines:
    - text: "\u2026Je reviens travailler, que \xE7a vous plaise ou non."
      speed: 0.02
    icone: {fileID: 21300000, guid: 900292dc5f2d09444b19781942b4d6e5, type: 3}
    Working: {fileID: 21300000, guid: d699784e5d57bca45ae9a43ce50f33a0, type: 3}
    Surcharge: {fileID: 21300000, guid: 2e684d57bd821084aab06be24cd3760c, type: 3}
