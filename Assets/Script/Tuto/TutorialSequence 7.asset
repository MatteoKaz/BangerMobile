    panelSize: {x: 0, y: 0}
    overridePanelPosition: 0
    panelPosition: {x: 0, y: 0}
  - text: "Les am\xE9liorations se divisent en deux cat\xE9gories : celles qui boostent
      un employ\xE9 individuel, et celles qui am\xE9liorent un p\xF4le entier."
    stepType: 0
    pauseOnShow: 0
    unpauseOnClose: 0
    overrideButtonSprite: 0
    buttonSprite: {fileID: 21300000, guid: adcee05d20d5e0b40b6c64ed512eb934, type: 3}
